{
    "permissions": {
      "allow": [
        "Edit",
        "Write",
        "Bash(uv run:*)",
        "Bash(gh:*)",
        "WebFetch(domain:data.alpaca.markets)"
      ],
      "defaultMode": "acceptEdits"
    },
    "sandbox": {
      "enabled": true,
      "autoAllowBashIfSandboxed": true,
      "filesystem": {
        "allowWrite": [
          "~/.cache/uv/",
          "/home/fbjarkes/claude/trading-bot",
          "/home/fbjarkes/claude/trading-bot/.worktrees/*/",
          "/tmp/"
        ],
        "allowRead": [
          "~/git/tickers-db/db/sqlite/tickers.sqlite"
        ]
      },
      "network": {
        "allowedDomains": [
          "data.alpaca.markets",
          "localhost:7498",
          "github.com",
          "*.github.com",
          "*.githubusercontent.com",
          "pypi.org",
          "files.pythonhosted.org"
        ]
      }
    }
}

